# Copy this file to .env on each computer and fill local values.
# Do not commit real secrets.

# Which connection profile this computer normally uses: local or remote.
ACCESS_PROFILE=local

# Default URL used by local tools on this computer.
HOME_ASSISTANT_URL=http://homeassistant.local:8123
HOME_ASSISTANT_TOKEN=replace-with-local-token
MCP_HOME_SERVER_URL=http://mini-pc.local:replace-port/private-path

# Optional explicit profiles.
HOME_ASSISTANT_LOCAL_URL=http://homeassistant.local:8123
HOME_ASSISTANT_REMOTE_URL=https://ha.example.invalid
MCP_HOME_LOCAL_SERVER_URL=http://mini-pc.local:replace-port/private-path
MCP_HOME_REMOTE_SERVER_URL=https://mcp.example.invalid/private-path
